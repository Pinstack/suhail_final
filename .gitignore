# YoYo AI version control directory
.yoyo/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib60/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# PEP 582; used by PDM, PEP 582 compatible installers
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# macOS
.DS_Store

# Local backup venv (not portable)
.venv_py39_backup/

# Environments
.env
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyderworkspace

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# VS Code
.vscode/

# Suhail Pipeline Specific
# Regenerated at runtime (scripts under logs/ stay tracked)
logs/*.pid

# Local BMAD agent bundles (not part of app source)
/.agents/
/_bmad/

/tiles_cache/
/temp_tiles/
/stitched/
/pipeline.log
/stitched_cache/

# Editor-specific ignore
.cursorignore

# Ignore built PDF documentation
*.pdf

# Ignore all GeoJSON files
*.geojson

# Caches and temporary files
stitched/
stitched_cache/
temp_tiles/
tiles_cache/

# Generated artifacts
temp_tiles/
stitched/
stitched_cache/
tiles_cache/

# Large DB / pipeline exports (GeoJSON dumps and archives)
outputs/*.geojson
outputs/*.zip
outputs/*.json
outputs/*.md
outputs/*.har
outputs/*.txt
outputs/.tmp.driveupload/
outputs/tmp_uploads/
test_tile_*.pbf
/tile_list.txt

# Regenerated DB report (keep README only)
docs/reports/generated/*.md
!docs/reports/generated/README.md

# Package metadata
*.egg-info/

# Legacy root report outputs
/flake8_report.txt
/vulture_report.txt

# Root-level data export noise
/retail_parcels.csv

# Allow all files in sample_data to be tracked, even if normally ignored
!/sample_data/
!/sample_data/**
.gstack/
